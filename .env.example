# ─── LLM provider (fallback chain) ─────────────────────────────────────────────
# The agent uses the FIRST working provider in this order:
#   1) Anthropic (Claude)      — set ANTHROPIC_API_KEY
#   2) OpenAI-compatible        — set the OPENAI_COMPAT_* trio (OpenAI/OpenRouter/Groq/…)
#   3) Local Ollama (free, no key) — run `ollama serve` + `ollama pull llama3.1`
# At least one must be available. Optional pin: LLM_PROVIDER=anthropic|openai-compat|ollama
#
# NOTE: a Cursor API key CANNOT be used here — Cursor's API is admin/cloud-agents
# only, not an LLM chat/completions endpoint. Use the OpenAI-compatible tier instead.

# 1) Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-...
# CLAUDE_MODEL=claude-opus-4-8

# 2) OpenAI-compatible (any provider exposing POST {base_url}/chat/completions)
OPENAI_COMPAT_BASE_URL=
OPENAI_COMPAT_API_KEY=
OPENAI_COMPAT_MODEL=

# 3) Local Ollama (free, no key). Defaults shown; just have Ollama running.
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_MODEL=llama3.1

# Optional: force one tier
# LLM_PROVIDER=

# ─── GitHub (real; works for PRIVATE repos) ────────────────────────────────────
# A Personal Access Token with access to your repo. For a PRIVATE repo this token
# is REQUIRED. Fine-grained token scopes: Contents: Read (ingest docs) +
# Issues: Read and write (read/create issues). Create at:
#   https://github.com/settings/tokens
GITHUB_TOKEN=

# ─── Embeddings (real semantic search) ─────────────────────────────────────────
# Provider: voyage | openai | ollama | hash
#   voyage : hosted; FREE tier is heavily rate-limited (429 on bulk ingest unless
#            you add a payment method at dash.voyageai.com — still large free quota).
#   ollama : LOCAL, real semantic, FREE, NO key, NO rate limit. RECOMMENDED if Voyage
#            throttles. Setup: install Ollama, then `ollama pull nomic-embed-text`.
#   openai : hosted (needs OPENAI_API_KEY).
#   hash   : offline lexical fallback — instant, no API, but not truly semantic.
EMBEDDING_PROVIDER=voyage
VOYAGE_API_KEY=
# VOYAGE_MODEL=voyage-3.5
OPENAI_API_KEY=
# For EMBEDDING_PROVIDER=ollama (uses OLLAMA_BASE_URL below):
# OLLAMA_EMBED_MODEL=nomic-embed-text

# ─── Vector DB: Qdrant ─────────────────────────────────────────────────────────
# Default = embedded LOCAL mode (no Docker), stored under data/qdrant.
# To use Qdrant Cloud (free tier) or a Docker container instead, set QDRANT_URL:
# QDRANT_URL=https://xxx.cloud.qdrant.io:6333
# QDRANT_API_KEY=
# QDRANT_PATH=data/qdrant
# QDRANT_COLLECTION=kb

# ─── Slack (read-only, optional) ───────────────────────────────────────────────
# Pull real messages from a Slack channel to triage. READ-ONLY — never posts.
# Create a Slack app (https://api.slack.com/apps) → add a Bot Token with scopes:
#   channels:read, channels:history, users:read   (+ groups:read, groups:history
#   for private channels). Install to workspace, copy the Bot token (xoxb-...),
#   and invite the bot to the channel:  /invite @your-bot
SLACK_BOT_TOKEN=

# ─── Plane engineering board (real, optional) ──────────────────────────────────
# Fill all three to file triaged issues onto a Plane project (the "Create in Plane"
# button creates a work item — it never reads/edits/deletes). If unset, use GitHub.
#   PLANE_API_KEY        : Plane → Settings → API tokens (personal API token)
#   PLANE_WORKSPACE_SLUG : the slug in your URL  app.plane.so/<slug>/...
#   PLANE_PROJECT_ID     : open the project; the UUID in the URL after /projects/
PLANE_API_KEY=
PLANE_WORKSPACE_SLUG=
PLANE_PROJECT_ID=
